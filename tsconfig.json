{
  "compilerOptions": {
    "lib": [
      "ES2021",
      "DOM"
    ],
    "target": "ES2021",
    "moduleResolution": "node",
    "module": "commonjs",
    "declaration": false,
    "removeComments": true,
    "sourceMap": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "dist",
    "rootDir": "./src",
    "baseUrl": "./",
    "incremental": true,
    "noEmitHelpers": true,
    "importHelpers": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "strictFunctionTypes": false,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": false,
    "alwaysStrict": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
